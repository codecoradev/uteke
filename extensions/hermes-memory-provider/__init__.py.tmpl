"""Uteke memory plugin — MemoryProvider interface.

Offline-first local memory backed by the `uteke` CLI (single Rust binary).
Recall uses local ONNX embeddings (no network). Fact extraction on session
end / pre-compress uses uteke's opt-in `import --extract` against an
OpenAI-compatible endpoint.

Why subprocess and not an SDK: uteke ships as a native binary, not a Python
package. We shell out to it. The binary path, namespace, and extraction
endpoint are all configurable.

Config via $HERMES_HOME/uteke.json (preferred) or environment variables:
  UTEKE_BIN           — path to the uteke binary (default: search PATH)
  UTEKE_HOME          — HOME dir uteke runs under (holds ~/.uteke store)
  UTEKE_NAMESPACE     — memory namespace (default: "default")
  UTEKE_EXTRACT       — "true"/"false": run LLM extraction on session end
  UTEKE_EXTRACT_MODEL — chat model for extraction
  UTEKE_EXTRACT_BASE_URL — OpenAI-compatible base URL
  UTEKE_EXTRACT_API_KEY  — API key for extraction (secret)
  UTEKE_RECALL_LIMIT  — number of memories to prefetch (default: 6)
  UTEKE_RECALL_MIN_SCORE — drop recall hits below this score (default: 0.45)
"""

from __future__ import annotations

import json
import logging
import os
import shutil
import subprocess
import tempfile
import threading
import time
from typing import Any, Dict, List

from agent.memory_provider import MemoryProvider
from tools.registry import tool_error

logger = logging.getLogger(__name__)

# Circuit breaker: after this many consecutive failures, pause calls
# for _BREAKER_COOLDOWN_SECS to avoid hammering a broken binary/endpoint.
_BREAKER_THRESHOLD = 5
_BREAKER_COOLDOWN_SECS = 120

# Subprocess timeouts (seconds)
_RECALL_TIMEOUT = 20
_REMEMBER_TIMEOUT = 20
_EXTRACT_TIMEOUT = 240


# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

def _load_config() -> dict:
    """Load config from env vars, overridden by $HERMES_HOME/uteke.json."""
    from hermes_constants import get_hermes_home

    def _envbool(key: str, default: bool) -> bool:
        v = os.environ.get(key)
        if v is None:
            return default
        return v.strip().lower() in ("1", "true", "yes", "on")

    config = {
        "bin": os.environ.get("UTEKE_BIN", ""),
        "uteke_home": os.environ.get("UTEKE_HOME", ""),
        "namespace": os.environ.get("UTEKE_NAMESPACE", "default"),
        "extract": _envbool("UTEKE_EXTRACT", True),
        "extract_model": os.environ.get("UTEKE_EXTRACT_MODEL", ""),
        "extract_base_url": os.environ.get("UTEKE_EXTRACT_BASE_URL", ""),
        "extract_api_key": os.environ.get("UTEKE_EXTRACT_API_KEY", ""),
        "recall_limit": int(os.environ.get("UTEKE_RECALL_LIMIT", "6") or 6),
        "recall_min_score": float(os.environ.get("UTEKE_RECALL_MIN_SCORE", "0.45") or 0.45),
    }

    config_path = get_hermes_home() / "uteke.json"
    if config_path.exists():
        try:
            file_cfg = json.loads(config_path.read_text(encoding="utf-8"))
            config.update({k: v for k, v in file_cfg.items()
                           if v is not None and v != ""})
        except Exception:
            pass

    return config


# ---------------------------------------------------------------------------
# Tool schemas
# ---------------------------------------------------------------------------

RECALL_SCHEMA = {
    "name": "uteke_recall",
    "description": (
        "Search long-term memory by meaning. Returns facts from prior sessions "
        "ranked by similarity. Use when you need context about the user, past "
        "decisions, or project details not already in this conversation."
    ),
    "parameters": {
        "type": "object",
        "properties": {
            "query": {"type": "string", "description": "What to search for."},
            "limit": {"type": "integer", "description": "Max results (default: 8, max: 25)."},
        },
        "required": ["query"],
    },
}

REMEMBER_SCHEMA = {
    "name": "uteke_remember",
    "description": (
        "Store a durable fact verbatim (no LLM extraction). Use for explicit "
        "preferences, corrections, or decisions worth keeping across sessions."
    ),
    "parameters": {
        "type": "object",
        "properties": {
            "content": {"type": "string", "description": "The fact to store."},
            "tags": {"type": "string", "description": "Optional comma-separated tags."},
        },
        "required": ["content"],
    },
}


# ---------------------------------------------------------------------------
# MemoryProvider implementation
# ---------------------------------------------------------------------------

class UtekeMemoryProvider(MemoryProvider):
    """Offline-first local memory via the uteke CLI."""

    def __init__(self):
        self._config: dict = {}
        self._bin = ""
        self._env = dict(os.environ)
        self._namespace = "default"
        self._extract = True
        self._extract_model = ""
        self._extract_base_url = ""
        self._extract_api_key = ""
        self._recall_limit = 6
        self._recall_min_score = 0.45

        self._session_id = ""
        self._platform = ""
        self._agent_identity = ""

        self._prefetch_result = ""
        self._prefetch_lock = threading.Lock()
        self._prefetch_thread = None
        self._sync_thread = None
        self._shutting_down = threading.Event()

        self._consecutive_failures = 0
        self._breaker_open_until = 0.0

    @property
    def name(self) -> str:
        return "uteke"

    # -- availability + config ----------------------------------------------

    def _resolve_bin(self, cfg: dict) -> str:
        b = cfg.get("bin") or ""
        if b and os.path.exists(b):
            return b
        found = shutil.which("uteke")
        return found or ""

    def is_available(self) -> bool:
        cfg = _load_config()
        return bool(self._resolve_bin(cfg))

    def save_config(self, values, hermes_home):
        from pathlib import Path
        config_path = Path(hermes_home) / "uteke.json"
        existing = {}
        if config_path.exists():
            try:
                existing = json.loads(config_path.read_text())
            except Exception:
                pass
        existing.update(values)
        config_path.write_text(json.dumps(existing, indent=2))

    def get_config_schema(self):
        return [
            {"key": "bin", "description": "Path to the uteke binary (blank = search PATH)", "env_var": "UTEKE_BIN"},
            {"key": "uteke_home", "description": "HOME dir uteke runs under (holds ~/.uteke store)", "env_var": "UTEKE_HOME"},
            {"key": "namespace", "description": "Memory namespace", "default": "default", "env_var": "UTEKE_NAMESPACE"},
            {"key": "extract", "description": "Run LLM fact extraction on session end", "default": "true", "choices": ["true", "false"], "env_var": "UTEKE_EXTRACT"},
            {"key": "extract_model", "description": "Chat model for extraction", "env_var": "UTEKE_EXTRACT_MODEL"},
            {"key": "extract_base_url", "description": "OpenAI-compatible base URL for extraction", "env_var": "UTEKE_EXTRACT_BASE_URL"},
            {"key": "extract_api_key", "description": "API key for extraction", "secret": True, "env_var": "UTEKE_EXTRACT_API_KEY"},
            {"key": "recall_limit", "description": "Memories to prefetch per turn", "default": "6", "env_var": "UTEKE_RECALL_LIMIT"},
        ]

    def initialize(self, session_id: str, **kwargs) -> None:
        cfg = _load_config()
        self._config = cfg
        self._bin = self._resolve_bin(cfg)
        self._namespace = cfg.get("namespace", "default")
        self._extract = bool(cfg.get("extract", True))
        self._extract_model = cfg.get("extract_model", "")
        self._extract_base_url = cfg.get("extract_base_url", "")
        self._extract_api_key = cfg.get("extract_api_key", "")
        self._recall_limit = int(cfg.get("recall_limit", 6) or 6)
        self._recall_min_score = float(cfg.get("recall_min_score", 0.45) or 0.45)

        self._session_id = str(session_id or "").strip()
        self._platform = kwargs.get("platform", "")
        self._agent_identity = kwargs.get("agent_identity", "")

        # uteke stores under $HOME/.uteke; let the user point it at a fixed home.
        self._env = dict(os.environ)
        uteke_home = cfg.get("uteke_home")
        if uteke_home:
            self._env["HOME"] = uteke_home

        logger.debug("Uteke initialized: bin=%s ns=%s extract=%s home=%s",
                     self._bin, self._namespace, self._extract, self._env.get("HOME"))

    # -- circuit breaker -----------------------------------------------------

    def _is_breaker_open(self) -> bool:
        if self._consecutive_failures < _BREAKER_THRESHOLD:
            return False
        if time.monotonic() >= self._breaker_open_until:
            self._consecutive_failures = 0
            return False
        return True

    def _record_success(self):
        self._consecutive_failures = 0

    def _record_failure(self):
        self._consecutive_failures += 1
        if self._consecutive_failures >= _BREAKER_THRESHOLD:
            self._breaker_open_until = time.monotonic() + _BREAKER_COOLDOWN_SECS
            logger.warning("Uteke circuit breaker tripped after %d failures; pausing %ds.",
                           self._consecutive_failures, _BREAKER_COOLDOWN_SECS)

    # -- subprocess helpers --------------------------------------------------

    def _run(self, args: List[str], *, timeout: int, stdin: str = None) -> subprocess.CompletedProcess:
        cmd = [self._bin] + args
        return subprocess.run(
            cmd, input=stdin, capture_output=True, text=True,
            timeout=timeout, env=self._env,
        )

    def _recall(self, query: str, limit: int) -> List[Dict[str, Any]]:
        """Return [{content, score, tags}] above min_score."""
        proc = self._run(
            ["recall", query, "--namespace", self._namespace,
             "--limit", str(limit), "--json"],
            timeout=_RECALL_TIMEOUT,
        )
        if proc.returncode != 0:
            raise RuntimeError(f"recall exit {proc.returncode}: {proc.stderr.strip()[:200]}")
        data = json.loads(proc.stdout or "[]")
        out = []
        for item in data:
            mem = item.get("memory", {}) if isinstance(item, dict) else {}
            score = item.get("score", 0.0) if isinstance(item, dict) else 0.0
            content = mem.get("content", "")
            if content and score >= self._recall_min_score:
                out.append({"content": content, "score": score, "tags": mem.get("tags", [])})
        return out

    # -- context recall (prefetch) ------------------------------------------

    def system_prompt_block(self) -> str:
        return (
            "# Uteke Memory (offline-first, persistent)\n"
            f"Active. Namespace: {self._namespace}. Local vector recall.\n"
            "Relevant memories are injected automatically before each turn. "
            "Use uteke_recall to search more, uteke_remember to store a fact."
        )

    def prefetch(self, query: str, *, session_id: str = "") -> str:
        if self._prefetch_thread and self._prefetch_thread.is_alive():
            self._prefetch_thread.join(timeout=3.0)
        with self._prefetch_lock:
            result = self._prefetch_result
            self._prefetch_result = ""
        if not result:
            return ""
        return f"## Uteke Memory\n{result}"

    def queue_prefetch(self, query: str, *, session_id: str = "") -> None:
        if self._shutting_down.is_set() or self._is_breaker_open() or not query.strip():
            return

        def _bg():
            try:
                hits = self._recall(query, self._recall_limit)
                if hits:
                    lines = "\n".join(f"- {h['content']}" for h in hits)
                    with self._prefetch_lock:
                        self._prefetch_result = lines
                self._record_success()
            except Exception as e:
                self._record_failure()
                logger.debug("Uteke prefetch failed: %s", e)

        self._prefetch_thread = threading.Thread(target=_bg, daemon=True, name="uteke-prefetch")
        self._prefetch_thread.start()

    # -- extraction on session boundaries -----------------------------------

    def _extract_messages(self, messages: List[Dict[str, Any]]) -> None:
        """Convert messages to clean text and run `import --extract` (blocking)."""
        if not self._extract:
            return
        text = _messages_to_text(messages)
        if len(text) < 50:
            return

        tmp = None
        try:
            with tempfile.NamedTemporaryFile("w", suffix=".txt", delete=False, encoding="utf-8") as fh:
                fh.write(text)
                tmp = fh.name
            args = [
                "import", tmp,
                "--namespace", self._namespace,
                "--extract",
                "--tags", f"hermes-session,{self._platform or 'cli'},session:{self._session_id}",
            ]
            if self._extract_model:
                args += ["--extract-model", self._extract_model]
            if self._extract_base_url:
                args += ["--extract-base-url", self._extract_base_url]
            if self._extract_api_key:
                args += ["--extract-api-key", self._extract_api_key]
            proc = self._run(args, timeout=_EXTRACT_TIMEOUT)
            if proc.returncode == 0:
                self._record_success()
                logger.debug("Uteke extract on session end: %s", proc.stdout.strip()[:120])
            else:
                self._record_failure()
                logger.warning("Uteke extract failed (%d): %s", proc.returncode, proc.stderr.strip()[:200])
        except Exception as e:
            self._record_failure()
            logger.warning("Uteke extract error: %s", e)
        finally:
            if tmp and os.path.exists(tmp):
                try:
                    os.unlink(tmp)
                except Exception:
                    pass

    def on_session_end(self, messages: List[Dict[str, Any]]) -> None:
        if self._shutting_down.is_set() or self._is_breaker_open():
            return
        # Run on a background thread so session teardown isn't blocked.
        t = threading.Thread(target=self._extract_messages, args=(messages,),
                             daemon=True, name="uteke-session-end")
        t.start()
        # Give it a head start but don't hang teardown indefinitely.
        t.join(timeout=_EXTRACT_TIMEOUT)

    def on_pre_compress(self, messages: List[Dict[str, Any]]) -> str:
        # Extract the about-to-be-discarded messages so they survive compaction.
        if not self._shutting_down.is_set() and not self._is_breaker_open():
            self._extract_messages(messages)
        return ""

    # -- manual tools --------------------------------------------------------

    def get_tool_schemas(self) -> List[Dict[str, Any]]:
        return [RECALL_SCHEMA, REMEMBER_SCHEMA]

    def handle_tool_call(self, tool_name: str, args: dict, **kwargs) -> str:
        if self._is_breaker_open():
            return tool_error("Uteke temporarily unavailable (consecutive failures). Will retry automatically.")

        if tool_name == "uteke_recall":
            query = args.get("query", "")
            if not query:
                return tool_error("Missing required parameter: query")
            limit = min(int(args.get("limit", 8) or 8), 25)
            try:
                hits = self._recall(query, limit)
                self._record_success()
                if not hits:
                    return json.dumps({"result": "No relevant memories found."})
                return json.dumps({"results": hits, "count": len(hits)})
            except Exception as e:
                self._record_failure()
                return tool_error(f"Recall failed: {e}")

        elif tool_name == "uteke_remember":
            content = args.get("content", "")
            if not content:
                return tool_error("Missing required parameter: content")
            cmd = ["remember", content, "--namespace", self._namespace]
            tags = args.get("tags", "")
            if tags:
                cmd += ["--tags", tags]
            try:
                proc = self._run(cmd, timeout=_REMEMBER_TIMEOUT)
                if proc.returncode != 0:
                    raise RuntimeError(proc.stderr.strip()[:200])
                self._record_success()
                return json.dumps({"result": "Fact stored."})
            except Exception as e:
                self._record_failure()
                return tool_error(f"Failed to store: {e}")

        return tool_error(f"Unknown tool: {tool_name}")

    def shutdown(self) -> None:
        self._shutting_down.set()
        for t in (self._prefetch_thread, self._sync_thread):
            if t and t.is_alive():
                t.join(timeout=5.0)


# ---------------------------------------------------------------------------
# Message -> clean text (mirrors hermes_session_to_text.py)
# ---------------------------------------------------------------------------

def _block_text(content: Any) -> str:
    if isinstance(content, str):
        return content.strip()
    if isinstance(content, list):
        parts = []
        for block in content:
            if isinstance(block, dict):
                if block.get("type") in (None, "text") and "text" in block:
                    parts.append(block["text"])
            elif isinstance(block, str):
                parts.append(block)
        return "\n".join(p.strip() for p in parts if p and p.strip())
    return ""


def _messages_to_text(messages: List[Dict[str, Any]]) -> str:
    out = []
    for msg in messages:
        role = msg.get("role")
        if role not in ("user", "assistant"):
            continue
        text = _block_text(msg.get("content"))
        if not text:
            continue
        label = "User" if role == "user" else "Assistant"
        out.append(f"{label}: {text}")
    return "\n\n".join(out)


def register(ctx) -> None:
    """Register Uteke as a memory provider plugin."""
    ctx.register_memory_provider(UtekeMemoryProvider())
